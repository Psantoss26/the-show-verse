{
  "manifest_version": 3,
  "name": "The Show Verse - Streaming Sync",
  "version": "1.4",
  "description": "Sincroniza automáticamente lo que ves en Netflix, Prime Video, Max, Disney+ y Plex con tu cuenta de The Show Verse en tiempo real.",
  "permissions": [
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.vercel.app/*",
    "https://theshowverse.com/*",
    "https://www.theshowverse.com/*",
    "https://*.netflix.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://*.vercel.app/*",
      "https://theshowverse.com/*",
      "https://www.theshowverse.com/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.netflix.com/*",
        "https://*.primevideo.com/*",
        "https://www.amazon.com/gp/video/*",
        "https://www.amazon.es/gp/video/*",
        "https://www.amazon.co.uk/gp/video/*",
        "https://www.amazon.de/gp/video/*",
        "https://play.max.com/*",
        "https://*.max.com/*",
        "https://play.hbomax.com/*",
        "https://*.disneyplus.com/*",
        "https://app.plex.tv/*"
      ],
      "js": ["content.js"],
      "all_frames": true
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.vercel.app/*",
        "https://theshowverse.com/*",
        "https://www.theshowverse.com/*"
      ],
      "js": ["content-showverse.js"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
