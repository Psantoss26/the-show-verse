NEXT_PUBLIC_TMDB_API_KEY=
NEXT_PUBLIC_API_BASE_URL=
BACKEND_API_BASE_URL=

# Netflix browser sync — instalación de un clic.
# Para que "Conectar" pueda instalar la extensión sin cargar la carpeta a mano,
# publica netflix-extension/ en la Chrome Web Store (y/o Edge Add-ons) y pega aquí
# el ID que te asigna la Store. La app abrirá la página de instalación y, en cuanto
# el usuario pulse "Añadir a Chrome", continuará la conexión automáticamente.
#   NEXT_PUBLIC_NETFLIX_EXTENSION_ID  → solo el ID (se construye la URL de la Store)
#   NEXT_PUBLIC_NETFLIX_EXTENSION_URL → URL completa (opcional, tiene prioridad)
NEXT_PUBLIC_NETFLIX_EXTENSION_ID=
NEXT_PUBLIC_NETFLIX_EXTENSION_URL=
