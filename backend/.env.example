# =====================================================
# The Show Verse — Backend API
# Copia este archivo como .env y rellena los valores
# =====================================================

# Servidor
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL — Neon
# DATABASE_URL: conexión POOLED (PgBouncer) — para queries normales
DATABASE_URL=postgresql://tsv_user:change_me@ep-XXXX.eu-west-2.aws.neon.tech/the_show_verse?sslmode=require
# DATABASE_URL_UNPOOLED: conexión DIRECTA — solo para migraciones (npm run db:migrate)
DATABASE_URL_UNPOOLED=postgresql://tsv_user:change_me@ep-XXXX.eu-west-2.aws.neon.tech/the_show_verse?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_CHARS_MIN
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Frontend (CORS)
FRONTEND_URL=http://localhost:3000

# TMDb (se usa como proxy con caché)
TMDB_API_KEY=

# Trakt (solo para importación de datos de usuario)
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_FAMILY_MONTHLY=

# Resend (emails transaccionales)
RESEND_API_KEY=
EMAIL_FROM=noreply@theshowverse.com

# Caché TTL (segundos)
CACHE_TTL_TMDB_DETAILS=600
CACHE_TTL_TMDB_TRENDING=300
CACHE_TTL_PROVIDERS=3600
