{
  "name": "the-show-verse-api",
  "version": "1.0.0",
  "description": "The Show Verse — Backend API (Fastify + PostgreSQL + Redis)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/db/migrate.js && node src/server.js",
    "deploy:check": "NODE_ENV=production node src/scripts/check-deploy.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.js",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node src/db/seed.js",
    "test": "node --test src/**/*.test.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.3.2",
    "jose": "^5.9.3",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
    "postgres": "^3.4.4",
    "resend": "^4.0.0",
    "stripe": "^16.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
