{
  "name": "the-show-verse-api",
  "version": "1.0.0",
  "description": "The Show Verse — Backend API (Fastify + PostgreSQL + Redis)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/db/migrate.js && node src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.js",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node src/db/seed.js",
    "test": "node --test src/**/*.test.js"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.41.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "jose": "^5.9.3",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
    "postgres": "^3.4.4",
    "resend": "^4.0.0",
    "stripe": "^16.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "dotenv": "^16.4.5",
    "pino-pretty": "^13.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
